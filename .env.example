# ============================================================
# AgentOS Simulation — Environment Configuration
# Copy to .env and fill in all REQUIRED values before starting
# ============================================================

# ---- SIMULATION MODE ----
SIM_MODE=real                        # 'real' | 'compressed' (15min = 1 sim day)
MOCK_AGENTS=false                    # true = bypass Claude API, use mock responses (dry run)
ORCHESTRATOR_CYCLE_MS=10000          # orchestrator loop interval in ms (default: 10 seconds)
TOTAL_EXPERIMENT_BUDGET_USD=200      # hard ceiling — system enforces this

# ---- ANTHROPIC (REQUIRED) ----
ANTHROPIC_API_KEY=sk-ant-...         # your Anthropic API key

# ---- SERVER (REQUIRED) ----
PORT=3411
HOST=0.0.0.0                        # bind to all interfaces for Tailscale access

# ---- DATABASE (REQUIRED) ----
DB_PATH=./sim.db                    # Bun SQLite — relative to agentOS-sim root

# ---- PRODUCT REPO (REQUIRED) ----
PRODUCT_REPO_PATH=/Users/manaswimarri/experiment-product    # absolute path

# ---- GOOGLE DRIVE (REQUIRED) ----
GDRIVE_SERVICE_ACCOUNT_PATH=.secrets/gdrive-service-account.json
GDRIVE_ROOT_FOLDER_ID=              # the folder ID from Drive setup (doc 5)

# ---- NOTION (REQUIRED) ----
NOTION_API_KEY=secret_...           # from notion.so/my-integrations
NOTION_DATABASE_ID=                 # the DB where agent logs sync

# ---- REDDIT (OPTIONAL — agents draft, human posts) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=                    # the disclosed bot account username
REDDIT_PASSWORD=
REDDIT_USER_AGENT=AgentOS-Experiment/1.0 (by /u/manaswimarri)

# ---- BUFFER (OPTIONAL — Twitter/LinkedIn scheduling) ----
BUFFER_ACCESS_TOKEN=
BUFFER_TWITTER_PROFILE_ID=
BUFFER_LINKEDIN_PROFILE_ID=

# ---- EMAIL OUTREACH (OPTIONAL) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=experiment@yourdomain.com

# ---- STOREFRONT (OPTIONAL — pick one) ----
GUMROAD_API_KEY=
LEMON_SQUEEZY_API_KEY=

# ---- ANALYTICS (OPTIONAL — recommended) ----
PLAUSIBLE_SITE_ID=
PLAUSIBLE_API_KEY=

# ---- ACTIVE WINDOW (real mode only) ----
ACTIVE_WINDOW_START=08:00           # agents only run between these hours in real mode
ACTIVE_WINDOW_END=22:00
ACTIVE_TIMEZONE=America/Chicago

# ---- LOGGING ----
LOG_LEVEL=info                      # 'debug' | 'info' | 'warn' | 'error'
LOG_DIR=./logs
